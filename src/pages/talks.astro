---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="Talks & Conferences — Adrian Besleaga"
    description="Conference talks and presentations by Adrian Besleaga — AI, Elasticsearch, OpenAI Embeddings, and more."
    canonicalUrl="https://adrianweb.xyz/talks"
>
    <div class="talks-page">
        <header class="oss-hero">
            <p class="hero-greeting">$ cat talks.md</p>
            <h1>Talks & <span class="accent">Conferences</span></h1>
            <p class="oss-subtitle">
                Presentations and tech talks I've given at industry events.
            </p>
        </header>

        <section class="oss-section">
            <div class="talks-list">
                <!-- 2025 — Las Vegas -->
                <div class="talk-card">
                    <div class="talk-card-accent"></div>
                    <div class="talk-card-gallery">
                        <img src="/Tech-Talk-2025-Vegas.jpeg" alt="Adrian Besleaga presenting 'Using AI, Expectations vs Reality' in Las Vegas 2025" class="talk-card-image" />
                        <img src="/Tech-Talk-2025-Vegas-1.jpeg" alt="Adrian Besleaga on stage at Las Vegas 2025 tech talk" class="talk-card-image" />
                    </div>
                    <div class="talk-card-inner">
                        <div class="talk-card-meta">
                            <span class="talk-location">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                Las Vegas
                            </span>
                            <span class="talk-year">2025</span>
                        </div>
                        <h3>Using AI, Expectations vs Reality</h3>
                        <p class="talk-desc">
                            A candid look at the gap between AI promises and real-world
                            outcomes — covering practical lessons learned from building
                            AI-powered products, common pitfalls, and what actually works
                            in production.
                        </p>
                        <div class="oss-card-tags">
                            <span class="oss-tag">AI</span>
                            <span class="oss-tag">Production</span>
                            <span class="oss-tag">Lessons Learned</span>
                        </div>
                    </div>
                </div>

                <!-- Nuxeo Connect 2023 — Las Vegas -->
                <a href="https://www.linkedin.com/feed/update/urn:li:activity:7120360607777792003/" target="_blank" rel="noreferrer" class="talk-card">
                    <div class="talk-card-accent"></div>
                    <img src="/Vegas-Talk.jpeg" alt="Adrian Besleaga presenting AI Content Assistant at a tech talk in Las Vegas" class="talk-card-image" />
                    <div class="talk-card-inner">
                        <div class="talk-card-meta">
                            <span class="talk-location">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                Las Vegas
                            </span>
                            <span class="talk-year">2023</span>
                        </div>
                        <h3>AI Content Assistant using OpenAI Embeddings and Elasticsearch</h3>
                        <p class="talk-desc">
                            Tech talk demonstrating how to build an AI-powered content
                            assistant by combining OpenAI Embeddings with Elasticsearch
                            for semantic search and intelligent content recommendations.
                        </p>
                        <div class="oss-card-tags">
                            <span class="oss-tag">AI</span>
                            <span class="oss-tag">OpenAI</span>
                            <span class="oss-tag">Elasticsearch</span>
                            <span class="oss-tag">Embeddings</span>
                        </div>
                        <div class="talk-cta">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                            View on LinkedIn →
                        </div>
                    </div>
                </a>
            </div>
        </section>
    </div>
</BaseLayout>
