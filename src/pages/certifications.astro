---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="Certifications — Adrian Besleaga"
    description="Professional certifications earned by Adrian Besleaga — AWS Certified, DeepLearning.AI AI for Good, and more."
    canonicalUrl="https://adrianweb.xyz/certifications"
>
    <div class="certs-page">
        <header class="oss-hero">
            <p class="hero-greeting">$ cat certifications.md</p>
            <h1>Certi<span class="accent">fications</span></h1>
            <p class="oss-subtitle">
                Professional certifications and continuing education in cloud,
                AI, and software engineering.
            </p>
        </header>

        <section class="oss-section">
            <div class="certs-list">
                <!-- AI for Good — DeepLearning.AI 2026 -->
                <article class="cert-card">
                    <div class="cert-card-accent"></div>
                    <div class="cert-card-inner">
                        <div class="cert-card-header">
                            <div class="cert-badge">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
                            </div>
                            <div class="cert-card-meta">
                                <span class="cert-issuer">DeepLearning.AI</span>
                                <span class="cert-year">May 2026</span>
                            </div>
                        </div>
                        <h3>AI for Good</h3>
                        <p class="cert-desc">
                            Professional Certificate covering applied AI for global
                            challenges — public health surveillance, climate change
                            modeling, and disaster response systems.
                        </p>
                        <ul class="cert-courses">
                            <li>AI and Public Health</li>
                            <li>AI and Climate Change</li>
                            <li>AI and Disaster Management</li>
                        </ul>
                        <div class="oss-card-tags">
                            <span class="oss-tag">AI</span>
                            <span class="oss-tag">Responsible AI</span>
                            <span class="oss-tag">3 Courses</span>
                        </div>
                        <div class="cert-actions">
                            <a
                                href="https://learn.deeplearning.ai/certificates/4c0b7e37-c71b-4581-b9ae-39f8e9f43a25"
                                target="_blank"
                                rel="noreferrer"
                                class="cert-link"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9 9 4.03 9 9z"/></svg>
                                Verify certificate
                            </a>
                            <a
                                href="https://www.linkedin.com/posts/adrian-besleaga_aiforgood-responsibleai-deeplearningai-share-7455925483784871936-hd4j"
                                target="_blank"
                                rel="noreferrer"
                                class="cert-link cert-link--linkedin"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                                LinkedIn post
                            </a>
                        </div>
                    </div>
                </article>

                <!-- AWS Certified -->
                <article class="cert-card">
                    <div class="cert-card-accent"></div>
                    <div class="cert-card-inner">
                        <div class="cert-card-header">
                            <div class="cert-badge cert-badge--aws">
                                <span aria-hidden="true">☁️</span>
                            </div>
                            <div class="cert-card-meta">
                                <span class="cert-issuer">Amazon Web Services</span>
                                <span class="cert-year">Active</span>
                            </div>
                        </div>
                        <h3>AWS Certified</h3>
                        <p class="cert-desc">
                            Cloud-native development and architecture on AWS — covering
                            compute, storage, networking, security, and managed services
                            for production workloads.
                        </p>
                        <div class="oss-card-tags">
                            <span class="oss-tag">AWS</span>
                            <span class="oss-tag">Cloud</span>
                            <span class="oss-tag">Architecture</span>
                        </div>
                        <div class="cert-actions">
                            <a
                                href="https://www.credly.com/badges/24f69965-8aa4-4d09-9336-a4e487292704/public_url"
                                target="_blank"
                                rel="noreferrer"
                                class="cert-link"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9 9 4.03 9 9z"/></svg>
                                Verify on Credly
                            </a>
                        </div>
                    </div>
                </article>
            </div>
        </section>
    </div>
</BaseLayout>

<style>
.certs-page {
    padding-bottom: 2rem;
}

.certs-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
}

.cert-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color var(--transition), transform var(--transition), background var(--transition), box-shadow var(--transition);
}

.cert-card:hover {
    border-color: var(--accent);
    background: var(--bg-card-hover);
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(86, 211, 100, 0.08);
}

.cert-card-accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--accent-gradient);
}

.cert-card-inner {
    padding: 1.75rem 1.75rem 1.75rem 2rem;
}

.cert-card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
}

.cert-badge {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(86, 211, 100, 0.12);
    color: var(--accent-green);
    border: 1px solid rgba(86, 211, 100, 0.25);
}

.cert-badge--aws {
    font-size: 1.6rem;
    background: rgba(255, 153, 0, 0.1);
    color: #ff9900;
    border-color: rgba(255, 153, 0, 0.3);
}

.cert-card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
}

.cert-issuer {
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--accent-green);
}

.cert-year {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
}

.cert-card h3 {
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
}

.cert-desc {
    color: var(--text-muted);
    font-size: 0.93rem;
    line-height: 1.65;
    margin-bottom: 1rem;
}

.cert-courses {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
}

.cert-courses li {
    position: relative;
    padding-left: 1.25rem;
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
    margin-bottom: 0.25rem;
}

.cert-courses li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--accent-green);
    font-weight: 700;
}

.cert-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1rem;
}

.cert-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent-green);
    font-family: var(--font-mono);
    text-decoration: none;
    transition: color var(--transition);
}

.cert-link:hover {
    color: var(--text);
}

.cert-link--linkedin {
    color: var(--text-muted);
}

@media (max-width: 640px) {
    .cert-card-inner {
        padding: 1.25rem 1.25rem 1.25rem 1.5rem;
    }

    .cert-card h3 {
        font-size: 1.15rem;
    }

    .cert-actions {
        gap: 0.75rem;
    }
}
</style>
